
++++++++++         # Contador na Célula 0 (valor 10)
[
  > +++++++        # Célula 1 (vai virar 70)
  > ++++++++++     # Célula 2 (vai virar 100)
  << -             # Volta para o contador
]
> +++++++++ .      # Célula 1: 70 + 9 = 79 ('O')
> +++++ .          # Célula 2: 100 + 5 = 105 ('i')

# Esse bloco te diz Oi